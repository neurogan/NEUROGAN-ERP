{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "prestart": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "node -e \"console.error('[stub] test:e2e — Playwright suite (login, QC ceremony, record-lock, audit export) lands in F-00 finalisation or F-04.'); process.exit(0)\"",
    "check:migrations": "tsx scripts/check-migrations.ts",
    "migrate:up": "drizzle-kit migrate",
    "migrate:dryrun-0013": "tsx server/scripts/dryrun-migration-0013.ts",
    "migrate:down": "node -e \"console.error('[stub] drizzle-kit has no native down migrations. Write an explicit reverse SQL file per AGENTS.md §5.2.'); process.exit(1)\"",
    "migrate:status": "node -e \"console.error('[stub] migrate:status: drizzle-kit does not expose status natively. Inspect the __drizzle_migrations table or parse drizzle/meta/_journal.json.'); process.exit(1)\"",
    "seed:test": "tsx scripts/seed-test.ts",
    "seed:users": "tsx scripts/seed-users.ts",
    "seed:validation": "tsx scripts/seed-validation.ts",
    "reset:validation-docs": "tsx scripts/reset-validation-docs.ts",
    "restore:check": "tsx scripts/restore-check.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "bufferutil",
      "esbuild"
    ]
  },
